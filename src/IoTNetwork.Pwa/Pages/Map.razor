@page "/map"
@inject IIoTTelemetryApi Api
@inject IJSRuntime Js

<PageTitle>Mapa</PageTitle>

<div class="flex min-h-0 flex-1 flex-col gap-4">
    <header class="flex flex-col gap-3 rounded-3xl bg-white p-5 shadow-md ring-1 ring-slate-200/80 dark:bg-slate-900 dark:ring-slate-700/80 md:p-6">
        <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
            <div>
                <h1 class="text-xl font-semibold tracking-tight text-slate-900 dark:text-white md:text-2xl">Mapa en vivo</h1>
                <p class="mt-1 text-sm text-slate-600 dark:text-slate-400 md:text-base">OpenStreetMap centrado en la última lectura con coordenadas del nodo seleccionado.</p>
            </div>
            @if (!string.IsNullOrWhiteSpace(_selectedNode))
            {
                <a href="@($"node/{Uri.EscapeDataString(_selectedNode)}")"
                   class="inline-flex min-h-11 shrink-0 items-center justify-center rounded-2xl border border-slate-200 bg-slate-50 px-4 text-sm font-semibold text-teal-700 shadow-sm transition hover:bg-teal-50 active:bg-teal-100/80 dark:border-slate-600 dark:bg-slate-800 dark:text-teal-300 dark:hover:bg-teal-950/50">
                    Historial del nodo
                </a>
            }
        </div>
        <div class="flex flex-col gap-2 sm:flex-row sm:items-center">
            <label class="text-sm font-medium text-slate-700 dark:text-slate-300" for="node">Nodo</label>
            <select id="node" class="min-h-12 flex-1 rounded-2xl border border-slate-200 bg-white px-3 text-base text-slate-900 shadow-sm focus:border-teal-500 focus:outline-none focus:ring-2 focus:ring-teal-500/30 dark:border-slate-600 dark:bg-slate-800 dark:text-white" value="@_selectedNode" @onchange="OnSelectChanged">
                @foreach (var n in _nodes)
                {
                    <option value="@n">@n</option>
                }
            </select>
            <button type="button" class="inline-flex min-h-12 items-center justify-center rounded-2xl bg-teal-600 px-4 text-base font-semibold text-white shadow-md shadow-teal-600/20 transition hover:bg-teal-700 active:bg-teal-800" @onclick="RefreshAsync">Actualizar</button>
        </div>
        @if (!string.IsNullOrEmpty(_error))
        {
            <p class="rounded-lg bg-rose-50 px-3 py-2 text-sm text-rose-800 ring-1 ring-rose-200 dark:bg-rose-950/40 dark:text-rose-200 dark:ring-rose-800">@_error</p>
        }
    </header>

    <div id="map-host" class="min-h-[42vh] w-full flex-1 overflow-hidden rounded-3xl bg-slate-200 shadow-inner ring-1 ring-slate-300/80 dark:bg-slate-800 dark:ring-slate-600/80 md:min-h-[50vh]"></div>

    @if (_last is not null)
    {
        <section aria-label="Lecturas del nodo">
            <p class="mb-2 text-xs font-medium uppercase tracking-wide text-slate-500 dark:text-slate-400">Toca un indicador para ver detalle (bajo / medio / alto)</p>
            <div class="grid grid-cols-2 gap-2 sm:grid-cols-4 md:gap-3">
                <MetricTapCard Title="Temperatura"
                               Value="@MetricViewHelper.FormatValue(_last, TelemetryMetricKind.Temperature)"
                               Band="MetricViewHelper.Band(_last, TelemetryMetricKind.Temperature)"
                               OnOpen="@(() => OpenMetricModal(TelemetryMetricKind.Temperature))" />
                <MetricTapCard Title="Humedad"
                               Value="@MetricViewHelper.FormatValue(_last, TelemetryMetricKind.Humidity)"
                               Band="MetricViewHelper.Band(_last, TelemetryMetricKind.Humidity)"
                               OnOpen="@(() => OpenMetricModal(TelemetryMetricKind.Humidity))" />
                <MetricTapCard Title="CO₂"
                               Value="@MetricViewHelper.FormatValue(_last, TelemetryMetricKind.Co2)"
                               Band="MetricViewHelper.Band(_last, TelemetryMetricKind.Co2)"
                               OnOpen="@(() => OpenMetricModal(TelemetryMetricKind.Co2))" />
                <MetricTapCard Title="Ruido"
                               Value="@MetricViewHelper.FormatValue(_last, TelemetryMetricKind.Noise)"
                               Band="MetricViewHelper.Band(_last, TelemetryMetricKind.Noise)"
                               OnOpen="@(() => OpenMetricModal(TelemetryMetricKind.Noise))" />
            </div>
            <p class="mt-3 text-center text-xs text-slate-500 dark:text-slate-500">Última muestra (UTC): @_last.TimestampUtc.ToString("u")</p>
        </section>
    }
</div>

<MetricReadingModal Open="ShowMetricModal"
                    OnClose="EventCallback.Factory.Create(this, CloseMetricModal)"
                    Reading="_last"
                    Title="@MetricModalTitle"
                    Subtitle="Lectura seleccionada"
                    ValueDisplay="@MetricModalValue"
                    Band="MetricModalBand"
                    BandLabel="@TelemetryLevels.BandLabelEs(MetricModalBand)"
                    BandHint="@MetricModalHint" />

@code {
    private readonly List<string> _nodes = [];
    private string? _selectedNode;
    private TelemetryReadingDto? _last;
    private string? _error;
    private Guid? _mapBoundReadingId;
    private TelemetryMetricKind? _metricModal;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var nodes = await Api.GetNodesAsync();
            _nodes.Clear();
            _nodes.AddRange(nodes);
            _selectedNode = _nodes.FirstOrDefault();
            await LoadLatestAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await TryMapAsync();
    }

    private async Task OnSelectChanged(ChangeEventArgs e)
    {
        _selectedNode = e.Value?.ToString();
        _mapBoundReadingId = null;
        _metricModal = null;
        _error = null;
        try
        {
            await LoadLatestAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task RefreshAsync()
    {
        _error = null;
        _mapBoundReadingId = null;
        _metricModal = null;
        try
        {
            var nodes = await Api.GetNodesAsync();
            _nodes.Clear();
            _nodes.AddRange(nodes);
            if (_selectedNode is null || !_nodes.Contains(_selectedNode))
            {
                _selectedNode = _nodes.FirstOrDefault();
            }

            await LoadLatestAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task LoadLatestAsync()
    {
        if (string.IsNullOrWhiteSpace(_selectedNode))
        {
            _last = null;
            return;
        }

        var to = DateTime.UtcNow;
        var from = to.AddDays(-7);
        var items = await Api.GetReadingsAsync(_selectedNode, from, to, 1);
        _last = items.FirstOrDefault();
    }

    private async Task TryMapAsync()
    {
        if (_last?.Latitude is null || _last.Longitude is null)
        {
            return;
        }

        if (_mapBoundReadingId == _last.Id)
        {
            return;
        }

        await Js.InvokeVoidAsync("iotMapDestroy", "map-host");
        await Js.InvokeVoidAsync("iotMapInit", "map-host", _last.Latitude, _last.Longitude, 13);
        _mapBoundReadingId = _last.Id;
    }

    private void OpenMetricModal(TelemetryMetricKind k) => _metricModal = k;

    private Task CloseMetricModal()
    {
        _metricModal = null;
        return Task.CompletedTask;
    }

    private bool ShowMetricModal => _metricModal.HasValue && _last is not null;

    private string MetricModalTitle =>
        _metricModal is null ? "" : MetricViewHelper.Title(_metricModal.Value);

    private string MetricModalValue =>
        _metricModal is null || _last is null
            ? "—"
            : MetricViewHelper.FormatValue(_last, _metricModal.Value);

    private MetricBand MetricModalBand =>
        MetricViewHelper.Band(_last, _metricModal ?? TelemetryMetricKind.Temperature);

    private string MetricModalHint =>
        _metricModal is null
            ? ""
            : TelemetryLevels.BandDescriptionEs(
                MetricViewHelper.MetricKey(_metricModal.Value),
                MetricModalBand);
}
