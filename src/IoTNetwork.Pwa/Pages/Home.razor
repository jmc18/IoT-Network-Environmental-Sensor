@page "/"

<PageTitle>IoT Network</PageTitle>

<div class="flex min-h-0 flex-1 flex-col gap-4 p-4 pb-24 md:pb-8">
    <section class="rounded-2xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
        <h1 class="text-2xl font-bold tracking-tight text-slate-900 md:text-3xl">IoT environmental map</h1>
        <p class="mt-3 max-w-prose text-base text-slate-600 md:text-lg">
            Progressive web app for tablets and phones. Connect ESP32 nodes to the API, then explore readings on the interactive map.
        </p>
        <a href="map" class="mt-6 inline-flex min-h-12 min-w-[44px] items-center justify-center rounded-xl bg-brand-600 px-5 text-base font-semibold text-white shadow-sm active:bg-brand-600/90">
            Open map
        </a>
    </section>
</div>
