@using IoTNetwork.Pwa.Services

<button type="button"
        class="flex min-h-[92px] w-full flex-col items-start gap-2 rounded-2xl border border-slate-200/90 bg-white p-3.5 text-left shadow-sm ring-1 ring-slate-100/80 transition active:scale-[0.99] dark:border-slate-600 dark:bg-slate-900 dark:ring-slate-700/80 border-l-4 @TelemetryLevels.BandCardAccent(Band)"
        @onclick="OnOpen">
    <span class="text-xs font-medium text-slate-500 dark:text-slate-400">@Title</span>
    <span class="text-lg font-bold tabular-nums text-slate-900 dark:text-white">@Value</span>
    <span class="rounded-full px-2 py-0.5 text-xs font-semibold @TelemetryLevels.BandBadgeTailwind(Band)">@TelemetryLevels.BandLabelEs(Band)</span>
</button>

@code {
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public string Value { get; set; } = "—";
    [Parameter] public MetricBand Band { get; set; }
    [Parameter] public EventCallback OnOpen { get; set; }
}
