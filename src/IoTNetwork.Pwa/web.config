<?xml version="1.0" encoding="utf-8"?>
<!--
  web.config para Blazor WebAssembly standalone hospedado en Azure App Service Windows (IIS).

  Este archivo se copia a la raíz del publish output. La estructura del sitio queda:
    /                  (site root, aquí vive este web.config)
    /wwwroot/          (todos los assets estáticos de la PWA)
    /wwwroot/index.html

  Responsabilidades:
  - Registrar MIME types necesarios para Blazor WASM (.wasm, .blat, .dat, .webmanifest...).
  - Rewrite "Serve subdir": redirige todas las peticiones a la carpeta wwwroot.
  - Rewrite "SPA fallback": si la URL no corresponde a un archivo físico, sirve index.html
    para que el router cliente de Blazor la maneje.
  - Cabecera Service-Worker-Allowed: "/" por si el SW se sirve desde un subpath.
-->
<configuration>
  <system.webServer>
    <staticContent>
      <remove fileExtension=".webmanifest" />
      <mimeMap fileExtension=".webmanifest" mimeType="application/manifest+json" />
      <remove fileExtension=".wasm" />
      <mimeMap fileExtension=".wasm" mimeType="application/wasm" />
      <remove fileExtension=".blat" />
      <mimeMap fileExtension=".blat" mimeType="application/octet-stream" />
      <remove fileExtension=".dat" />
      <mimeMap fileExtension=".dat" mimeType="application/octet-stream" />
      <remove fileExtension=".dll" />
      <mimeMap fileExtension=".dll" mimeType="application/octet-stream" />
      <remove fileExtension=".pdb" />
      <mimeMap fileExtension=".pdb" mimeType="application/octet-stream" />
      <remove fileExtension=".json" />
      <mimeMap fileExtension=".json" mimeType="application/json" />
      <remove fileExtension=".woff" />
      <mimeMap fileExtension=".woff" mimeType="application/font-woff" />
      <remove fileExtension=".woff2" />
      <mimeMap fileExtension=".woff2" mimeType="application/font-woff2" />
    </staticContent>

    <httpProtocol>
      <customHeaders>
        <add name="Service-Worker-Allowed" value="/" />
      </customHeaders>
    </httpProtocol>

    <rewrite>
      <rules>
        <rule name="Serve subdir">
          <match url=".*" />
          <action type="Rewrite" url="wwwroot/{R:0}" />
        </rule>
        <rule name="SPA fallback routing" stopProcessing="true">
          <match url=".*" />
          <conditions logicalGrouping="MatchAll">
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
            <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
          </conditions>
          <action type="Rewrite" url="wwwroot/index.html" />
        </rule>
      </rules>
    </rewrite>
  </system.webServer>
</configuration>
